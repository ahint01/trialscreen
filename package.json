{
  "name": "trialscreen",
  "version": "1.0.0",
  "private": true,
  "description": "Clinical trial screening tool",
  "workspaces": [
    "apps/trialscreen-backend",
    "apps/trialscreen-frontend",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w trialscreen-backend",
    "dev:frontend": "npm run dev -w trialscreen-frontend",
    "build": "npm run build -w trialscreen-backend && npm run build -w trialscreen-frontend",
    "db:migrate": "npm run db:migrate -w trialscreen-backend",
    "test": "npm run test -w trialscreen-backend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahint01/trialscreen.git"
  },
  "license": "ISC"
}
